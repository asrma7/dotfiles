{
  "html.format.indentInnerHtml": true,
  "html.format.templating": true,
  "editor.linkedEditing": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "editor.accessibilitySupport": "off",
  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "git.autofetch": true,
  "[python]": {
    "editor.formatOnType": true
  },
  "security.workspace.trust.untrustedFiles": "open",
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.rulers": [
      80
    ],
    "editor.selectionHighlight": false,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": "off"
  },
  "git.confirmSync": false,
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "redhat.telemetry.enabled": true,
  "vs-kubernetes": {
    "vscode-kubernetes.helm-path.windows": "C:\\Users\\ashut\\.vs-kubernetes\\tools\\helm\\windows-amd64\\helm.exe"
  },
  "yaml.customTags": [
    "!And",
    "!And sequence",
    "!If",
    "!If sequence",
    "!Not",
    "!Not sequence",
    "!Equals",
    "!Equals sequence",
    "!Or",
    "!Or sequence",
    "!FindInMap",
    "!FindInMap sequence",
    "!Base64",
    "!Join",
    "!Join sequence",
    "!Cidr",
    "!Ref",
    "!Sub",
    "!Sub sequence",
    "!GetAtt",
    "!GetAZs",
    "!ImportValue",
    "!ImportValue sequence",
    "!Select",
    "!Select sequence",
    "!Split",
    "!Split sequence"
  ],
  "aws.suppressPrompts": {
    "codeWhispererConnectionExpired": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "terminal.integrated.env.windows": {},
  "console-ninja.featureSet": "Community",
  "dart.flutterSdkPath": "C:\\Users\\ashut\\flutter",
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb",
    "pubspec.yaml": "pubspec.lock,pubspec_overrides.yaml,.packages,.flutter-plugins,.flutter-plugins-dependencies,.metadata",
    "*.dart": "${capture}.g.dart",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  },
  "workbench.colorTheme": "Material Code",
  "vim.neovimUseConfigFile": true,
  "vim.enableNeovim": true,
  "vim.highlightedyank.enable": true,
  "vim.leader": " ",
  "vim.smartRelativeLine": true,
  "vscode-edge-devtools.webhintInstallNotification": true,
  "remote.SSH.remotePlatform": {
    "40.233.66.227": "linux"
  },
  "liveServer.settings.donotVerifyTags": true,
  "terminal.integrated.fontFamily": "IosevkaAsrma7 Nerd Font",
  "makefile.configureOnOpen": false,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gemini-3.1-pro-preview",
  "editor.fontFamily": "IosevkaAsrma7 Nerd Font",
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": false,
    "scminput": false
  },
  "editor.semanticHighlighting.enabled": true,
  "window.dialogStyle": "custom",
  "window.menuBarVisibility": "hidden",
  "material-code.colors": {
    "primary": "#87d6bd",
    "foreground": "#dee4e0",
    "mutedForeground": "#bfc9c4",
    "background": "#0f1512",
    "card": "#1b211e",
    "popover": "#252b29",
    "hover": "#303633",
    "border": "#3f4945",
    "primaryForeground": "#00382c",
    "secondary": "#344c44",
    "secondaryForeground": "#cde9de",
    "syntax.comment": "#89938e",
    "syntax.string": "#70a8cf",
    "syntax.keyword": "#1aae8d",
    "syntax.variable": "#dee4e0",
    "syntax.attribute": "#1d352e",
    "syntax.property": "#a9cbe2",
    "syntax.function": "#b2ccc2",
    "syntax.constant": "#1f739b"
  }
}
