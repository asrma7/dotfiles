#!/usr/bin/env bash

APP_NAME="Power Monitor"

STATE_DIR="${XDG_RUNTIME_DIR:-/run/user/1000}/battery-notify"
mkdir -p "$STATE_DIR"

ICON_LOW="/usr/share/icons/Papirus-Light/24x24/panel/battery-caution.svg"
ICON_CRITICAL="/usr/share/icons/Papirus-Light/24x24/panel/battery-empty.svg"
ICON_SUSPEND="/usr/share/icons/Papirus-Light/24x24/panel/battery-empty.svg"

battery_info="$(acpi -b | head -n 1)"
[ -n "$battery_info" ] || exit 0

status="${battery_info#*: }"
status="${status%%,*}"
capacity="${battery_info#*, }"
capacity="${capacity%%\%*}"
capacity="${capacity//[^0-9]/}"

if [ "$status" != "Discharging" ]; then
  rm -f "$STATE_DIR"/low "$STATE_DIR"/critical "$STATE_DIR"/final "$STATE_DIR"/suspend
  exit 0
fi

if [ "$capacity" -le 20 ] && [ ! -f "$STATE_DIR/low" ]; then
  /usr/bin/notify-send -a "$APP_NAME" -h string:synchronous:battery -u normal -i "$ICON_LOW" \
    "Battery status" \
    "Battery is low at ${capacity}%."

  touch "$STATE_DIR/low"
fi

if [ "$capacity" -le 10 ] && [ ! -f "$STATE_DIR/critical" ]; then
  /usr/bin/notify-send -a "$APP_NAME" -h string:synchronous:battery -u critical -i "$ICON_CRITICAL" \
    "Battery status" \
    "Battery is critically low at ${capacity}%."

  touch "$STATE_DIR/critical"
fi

if [ "$capacity" -le 7 ] && [ ! -f "$STATE_DIR/final" ]; then
  /usr/bin/notify-send -a "$APP_NAME" -h string:synchronous:battery -u critical -i "$ICON_SUSPEND" \
    "Battery status" \
    "Battery is at ${capacity}%. Suspending soon unless plugged in."

  touch "$STATE_DIR/final"
fi

if [ "$capacity" -le 5 ] && [ ! -f "$STATE_DIR/suspend" ]; then
  touch "$STATE_DIR/suspend"

  /usr/bin/notify-send -a "$APP_NAME" -h string:synchronous:battery -u critical -i "$ICON_SUSPEND" \
    "Battery status" \
    "Battery is at ${capacity}%. Suspending in 20 seconds."

  sleep 20

  battery_info="$(acpi -b | head -n 1)"
  [ -n "$battery_info" ] || exit 0

  status="${battery_info#*: }"
  status="${status%%,*}"
  capacity="${battery_info#*, }"
  capacity="${capacity%%\%*}"
  capacity="${capacity//[^0-9]/}"

  if [ "$status" = "Discharging" ] && [ "$capacity" -le 5 ]; then
    systemctl suspend
  fi
fi
